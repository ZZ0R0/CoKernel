# Kbuild Makefile for the co-kernel loader module (parasite.ko)
#
# - The cokernel_blob.h is generated by scripts/build_module.sh
#   before invoking kbuild, so it's available at compile time.
#
# - This file is invoked by: make -C $KDIR M=$PWD modules
#

MODULE_NAME := parasite

obj-m := $(MODULE_NAME).o

$(MODULE_NAME)-y := parasite_main.o \
                    memory.o        \
                    pagetable.o     \
                    execution.o     \
                    resolve.o       \
                    stealth.o       \
                    pmi_entry.o

ccflags-y := -I$(src)/../include
